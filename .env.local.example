# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Gmail SMTP)
# SMTP_USER = the underlying Google account you authenticate against
# SMTP_FROM = optional — if SMTP_USER is the real account and you want emails to appear
#             from an alias (e.g. tryouts@), set SMTP_FROM to that alias. The alias must
#             be configured as a "Send mail as" address in SMTP_USER's Gmail settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=info@peacesoccerschool.com
SMTP_FROM=tryouts@peacesoccerschool.com
SMTP_PASS=
# Where to send "new signup" notifications. Comma-separate for multiple recipients.
# Defaults to SMTP_USER if unset.
ADMIN_NOTIFY_EMAIL=

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Meta Lead Ads webhook — for Facebook/Instagram Lead Form submissions
# - META_VERIFY_TOKEN is what you set in Meta's webhook config; must match.
# - META_APP_SECRET is the App Secret from your Meta App (used to verify HMAC SHA256
#   signatures on incoming webhooks).
# - META_ACCESS_TOKEN is a page access token (or system user token) with
#   leads_retrieval permission so we can call the Graph API to fetch full
#   lead field values.
META_VERIFY_TOKEN=pss-meta-leads-2026
META_APP_SECRET=
META_ACCESS_TOKEN=

# Admin dashboard
ADMIN_PASSWORD=

# Anthropic (AI auto-reply on WhatsApp)
ANTHROPIC_API_KEY=
AI_AUTO_REPLY_ENABLED=true

# Tryout event defaults
TRYOUT_DATE=2026-08-15
TRYOUT_TIME=09:00
TRYOUT_LOCATION=Bliss Fields, Rehoboth MA
