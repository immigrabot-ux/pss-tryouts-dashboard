# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Gmail SMTP)
# SMTP_USER = the underlying Google account you authenticate against
# SMTP_FROM = optional — if SMTP_USER is the real account and you want emails to appear
#             from an alias (e.g. tryouts@), set SMTP_FROM to that alias. The alias must
#             be configured as a "Send mail as" address in SMTP_USER's Gmail settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=info@peacesoccerschool.com
SMTP_FROM=tryouts@peacesoccerschool.com
SMTP_PASS=
# Where to send "new signup" notifications. Comma-separate for multiple recipients.
# Defaults to SMTP_USER if unset.
ADMIN_NOTIFY_EMAIL=

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Admin dashboard
ADMIN_PASSWORD=

# Anthropic (AI auto-reply on WhatsApp)
ANTHROPIC_API_KEY=
AI_AUTO_REPLY_ENABLED=true

# Tryout event defaults
TRYOUT_DATE=2026-08-15
TRYOUT_TIME=09:00
TRYOUT_LOCATION=Bliss Fields, Rehoboth MA
